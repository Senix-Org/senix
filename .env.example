# =============================================================================
# Senix environment variables
#
# Copy to `.env.local` (or set in the Vercel project) and fill in real values.
# Values here are placeholders only — never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Public URLs (exposed to the browser; must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------

# Canonical public base URL of the app. Used for SEO metadata, sitemap,
# robots, OG image, and the MCP server URL shown in the Connect IDE flow.
NEXT_PUBLIC_APP_URL=https://senix-chi.vercel.app

# Base URL used for fire-and-forget internal dispatch (webhook -> analyze-pr)
# and as a metadata fallback. Set to the same value as NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_SITE_URL=https://senix-chi.vercel.app

# Supabase project URL and anon key (browser/client + middleware auth).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# GitHub App slug (the URL segment at github.com/apps/<slug>). Used to build
# the "Connect a repo" install URL.
NEXT_PUBLIC_GITHUB_APP_SLUG=senix

# -----------------------------------------------------------------------------
# Supabase (server-side, service role — never exposed to the browser)
# -----------------------------------------------------------------------------

# Supabase project URL for the admin client.
SUPABASE_URL=https://your-project.supabase.co

# Service-role key. Full database access, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# GitHub App (webhook auth + installation API access)
# -----------------------------------------------------------------------------

# Numeric GitHub App ID.
GITHUB_APP_ID=123456

# GitHub App private key (PEM). Keep the literal newlines or use \n escapes.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Secret configured on the GitHub App webhook; verifies incoming payloads.
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# -----------------------------------------------------------------------------
# LLM providers (analysis engine)
# -----------------------------------------------------------------------------

# Primary provider to try first: deepseek | groq | gemini | anthropic.
# Others are used as automatic failover when their keys are present.
LLM_PROVIDER=deepseek

# Provider API keys. Configure at least the one named in LLM_PROVIDER.
DEEPSEEK_API_KEY=your-deepseek-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# Upstash Redis (optional fallback queue for the standalone worker)
# -----------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# -----------------------------------------------------------------------------
# Internal / operational
# -----------------------------------------------------------------------------

# Shared secret the webhook uses to authenticate its call to the internal
# /api/internal/analyze-pr function. Required for the serverless analyze path.
INTERNAL_WORKER_SECRET=your-internal-worker-secret

# Password gating the /internal/* operator pages and internal queue routes.
INTERNAL_PASSWORD=your-internal-password

# Whether to actually post PR comments to GitHub. Defaults to true; set to
# "false" only to suppress comments (e.g. local testing).
POST_PR_COMMENTS=true

# Standalone worker log format: json | pretty.
WORKER_LOG_FORMAT=pretty

# -----------------------------------------------------------------------------
# Whop billing
# -----------------------------------------------------------------------------

# Whop API key (server-side checkout link creation + cancellation).
WHOP_API_KEY=your-whop-api-key

# Secret used to verify incoming Whop webhook signatures.
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret

# Whop company ID. Optional; skips a product lookup when set.
WHOP_COMPANY_ID=your-whop-company-id

# Pre-created Whop plan IDs (plan_...) with hosted checkout pages. Preferred
# path — one per plan and billing period.
WHOP_STARTER_MONTHLY_ID=plan_xxxxxxxxxxxxx
WHOP_STARTER_YEARLY_ID=plan_xxxxxxxxxxxxx
WHOP_TEAM_MONTHLY_ID=plan_xxxxxxxxxxxxx
WHOP_TEAM_YEARLY_ID=plan_xxxxxxxxxxxxx
WHOP_PRO_MONTHLY_ID=plan_xxxxxxxxxxxxx
WHOP_PRO_YEARLY_ID=plan_xxxxxxxxxxxxx

# Legacy Whop product IDs. Fallback used to build a plan dynamically (monthly
# only) when the direct plan IDs above are not configured.
WHOP_STARTER_PRODUCT_ID=prod_xxxxxxxxxxxxx
WHOP_TEAM_PRODUCT_ID=prod_xxxxxxxxxxxxx
WHOP_PRO_PRODUCT_ID=prod_xxxxxxxxxxxxx
